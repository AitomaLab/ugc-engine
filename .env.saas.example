# ============================================================================
# UGC Engine SaaS — Environment Variables (.env.saas)
# ============================================================================
# Copy this file to .env.saas and fill in your keys.

# --- Core API Keys ---
# Kie.ai: Sign up at https://kie.ai and get your API key
KIE_API_KEY=your_kie_api_key_here

# WaveSpeed: Sign up at https://wavespeed.ai for Veo 3.1 / Kling / NanoBanana fallback
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# Route UGC Veo 3.1 (8s/15s/30s) to WaveSpeed during Kie Veo outages (default: false)
# UGC_FORCE_WAVESPEED=true

# Fail UGC Veo jobs when WAVESPEED_API_KEY is missing (Modal worker sets this via secrets)
# UGC_REQUIRE_WAVESPEED=true

# Prefer WaveSpeed for all Veo paths on Creative OS (default: false on COS, true on worker)
# USE_WAVESPEED_PRIMARY=true

# ElevenLabs: Sign up at https://elevenlabs.io and get your API key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI: Sign up at https://platform.openai.com and get your API key
# Used for Whisper transcription (subtitle sync)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic: Required for the in-editor AI assistant (AiAgentPanel)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional override (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database (Supabase PostgreSQL) ---
# Get this from Supabase Dashboard > Database > Connection String > URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Supabase Storage & Client ---
# Get these from Supabase Dashboard > Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
# JWT secret for local token validation (Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Background Task Queue (Redis) ---
# Optional for local dev — backend auto-falls back to in-process threads
# For production: rediss://:password@hostname:port
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Frontend Connectivity ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Invite-code gated signup. Set true only when launching gated beta.
NEXT_PUBLIC_REQUIRE_INVITE_CODE=false

# --- Stripe Payments ---
# Get these from Stripe Dashboard > Developers > API keys (Live mode for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Live webhook: Dashboard > Developers > Webhooks (Live mode) > endpoint signing secret
# Endpoint URL: https://<your-railway-api-host>/api/stripe/webhook
# Events: checkout.session.completed, invoice.paid, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Top-up package Stripe Price IDs are stored in Supabase (credit_topup_packages table).
# See ugc_db/migrations/065_credit_topup_packages.sql and docs/stripe-billing-ops.md.
# Stripe Customer Portal login URL (Settings > Billing > Customer portal > Login link)
NEXT_PUBLIC_STRIPE_BILLING_PORTAL_URL=https://checkout.aitoma.studio/p/login/9B628r9LS1xa0o63hv0Ny00
# Frontend base URL for Stripe redirect URLs (fallback if Origin header missing)
FRONTEND_URL=https://your-app.vercel.app

# --- Beta onboarding (paid plan before ICP) ---
# Backend: 0 disables welcome signup credits; 100 re-enables (default 100)
WELCOME_SIGNUP_CREDITS=0
# Frontend: true shows SubscribeGate before onboarding questions
NEXT_PUBLIC_REQUIRE_PAID_PLAN=true

# ============================================================================
# Publish / Scheduling — Ayrshare (social posting & connections)
# ============================================================================
# Get your key + domain from https://app.ayrshare.com (Business plan for JWT links)
AYRSHARE_API_KEY=your_ayrshare_api_key_here
AYRSHARE_DOMAIN=your_ayrshare_app_domain
# Provide the private key inline OR via a file path (one of the two):
AYRSHARE_PRIVATE_KEY=
# AYRSHARE_PRIVATE_KEY_PATH=./References/Ayrshare key/your-private-key.key
# HMAC secret to validate inbound Ayrshare webhooks (optional but recommended)
AYRSHARE_WEBHOOK_SECRET=
# Where users return after linking an account in the Ayrshare popup
AYRSHARE_LINK_REDIRECT_URL=http://localhost:3000/connections?linked=1

# ============================================================================
# Analytics module (Publish → Analytics tab) — BrightData + Gemini
# ============================================================================
# BrightData API key for external post/account scraping (scrapes fail without it)
BRIGHTDATA_API_KEY=your_brightdata_api_key_here
# BrightData dataset IDs (per platform / post vs profile)
BRIGHTDATA_TIKTOK_POST_DATASET_ID=
BRIGHTDATA_TIKTOK_PROFILE_DATASET_ID=
BRIGHTDATA_INSTAGRAM_POST_DATASET_ID=
BRIGHTDATA_INSTAGRAM_PROFILE_DATASET_ID=
# Google Gemini key for AI video breakdowns (google-genai Files API).
# KIE_API_KEY alone is NOT sufficient. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# Optional alternative vision provider (used only if GEMINI_API_KEY is absent)
# FAL_KEY=
# BRIGHTDATA_MOCK=false

# ============================================================================
# Admin invite console (hidden gated-beta) — Brevo waitlist sync
# ============================================================================
# Only this email may access /admin/invites and the /api/admin/* endpoints
ADMIN_EMAIL=saas@aitoma.ai
# Brevo (Sendinblue) contacts API for invite-code generation/sync
BREVO_API_KEY=your_brevo_api_key_here
# Optional: restrict the waitlist pull to a single Brevo list id (empty = all)
BREVO_LIST_ID=
# Frontend base URL used to build invite links in the admin console
NEXT_PUBLIC_SIGNUP_BASE_URL=http://localhost:3000
