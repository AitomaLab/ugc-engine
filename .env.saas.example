# ============================================================================
# UGC Engine SaaS — Environment Variables (.env.saas)
# ============================================================================
# Copy this file to .env.saas and fill in your keys.

# --- Core API Keys ---
# Kie.ai: Sign up at https://kie.ai and get your API key
KIE_API_KEY=your_kie_api_key_here

# ElevenLabs: Sign up at https://elevenlabs.io and get your API key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI: Sign up at https://platform.openai.com and get your API key
# Used for Whisper transcription (subtitle sync)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic: Required for the in-editor AI assistant (AiAgentPanel)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional override (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database (Supabase PostgreSQL) ---
# Get this from Supabase Dashboard > Database > Connection String > URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Supabase Storage & Client ---
# Get these from Supabase Dashboard > Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# --- Background Task Queue (Redis) ---
# Optional for local dev — backend auto-falls back to in-process threads
# For production: rediss://:password@hostname:port
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Frontend Connectivity ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Stripe Payments ---
# Get these from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Get from Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Stripe Price IDs for one-time credit top-up packages (from Product Catalog)
STRIPE_TOPUP_SMALL_PRICE_ID=price_small_topup_id_here
STRIPE_TOPUP_MEDIUM_PRICE_ID=price_medium_topup_id_here
STRIPE_TOPUP_LARGE_PRICE_ID=price_large_topup_id_here
STRIPE_TOPUP_XL_PRICE_ID=price_xl_topup_id_here
# Frontend URL for Stripe redirect URLs (fallback if Origin header missing)
FRONTEND_URL=https://your-app.vercel.app
